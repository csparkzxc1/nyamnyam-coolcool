# Default: all files handled as text with LF line endings
* text=auto eol=lf

# Explicit text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.css text eol=lf
*.html text eol=lf
*.env.example text eol=lf

# Explicit binary files (don't apply text rules)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
